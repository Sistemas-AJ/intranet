# Environment configuration for intranet-aj

# Server port
# (the Docker container is configured to use 3500 by default)
PORT=3500

# Database filename (placed inside ./data). Default is database.sqlite
DB_FILE=intranet.sqlite

# Administrator credentials (avoid checked-in defaults in real deployments)
ADMIN_USUARIO=AJADMINISTRADOR
ADMIN_CONTRASENA=197720

# JWT secret used to sign login tokens (change for production!)
JWT_SECRET=your-super-secret
# Number of bcrypt salt rounds for hashing passwords
SALT_ROUNDS=10

# Comma-separated list of allowed CORS origins for the frontend
ALLOWED_ORIGINS=http://localhost:5173, http://127.0.0.1:5173/

# Frontend dev server will proxy /api to this URL (used by Vite)
# set to your backend address; in production the frontend should call
# the same host that serves the build files.
VITE_API_URL=http://localhost:3000

# For future Postgres support you can specify a connection string here;
# leaving it empty will use the bundled SQLite database instead.
DATABASE_URL=
